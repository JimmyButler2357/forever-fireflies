{
  "expo": {
    "name": "Forever Fireflies",
    "slug": "forever-fireflies",
    "version": "1.0.2",
    "scheme": "forever-fireflies",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foreverfireflies.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Forever Fireflies uses your microphone to record voice memories.",
        "NSSpeechRecognitionUsageDescription": "Forever Fireflies uses speech recognition to transcribe your voice recordings.",
        "NSLocationWhenInUseUsageDescription": "Forever Fireflies tags where your memories happen so you can look back on them later."
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8724A"
      },
      "versionCode": 5,
      "package": "com.foreverfireflies.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Forever Fireflies uses your microphone to record voice memories."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Forever Fireflies uses your microphone to record voice memories.",
          "speechRecognitionPermission": "Forever Fireflies uses speech recognition to transcribe your voice recordings."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E8724A"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Forever Fireflies tags where your memories happen so you can look back on them later."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Forever Fireflies uses your photos to attach images to your memories.",
          "cameraPermission": "Forever Fireflies uses your camera to capture photos for your memories."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@sentry/react-native/expo",
        {
          "organization": "foreverfireflies",
          "project": "forever-fireflies",
          "enableAutoUpload": true
        }
      ],
      "@sentry/react-native",
      "expo-font"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "router": { "origin": "https://foreverfireflies.app" },
      "eas": {
        "projectId": "28237d21-d29f-4e56-a83d-002d9d20739f"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/28237d21-d29f-4e56-a83d-002d9d20739f"
    }
  }
}
